// This is your Prisma schema file,
// 1. The `url` property inside the `datasource` block is correctly written for older Prisma versions, but in Prisma 5.7.0+ (aka Prisma 7), connection URLs for migrations must go in `prisma.config.ts`, not here. However, usage inside the Prisma Client itself (for running `prisma generate` and runtime usage) is still supported, so for most use-cases (and local development), the following is still valid unless ONLY using migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User model - for managing users who submit/review reports
// User model - handles authentication and roles
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      String   @default("viewer") // admin, reviewer, viewer
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Opposite relation fields required by Prisma
  reports  Report[]
  comments Comment[]

  @@map("users")
}

// Report model - aligned with Uwazi UI (Kenya Counties, Anonymous status)
model Report {
  id          String  @id @default(cuid())
  title       String
  description String?
  category    String // e.g., "Judiciary", "Police"

  // UI Specific fields from screenshots
  county      String // For Kenya Counties dropdown
  location    String? // "Specific area"
  isAnonymous Boolean  @default(false)
  authorName  String? // Store "Anonymous Report" or typed name
  evidence    String[] // Array of URLs for Photos/Videos

  status   String @default("pending") // e.g., "Under Investigation"
  priority String @default("medium")
  upvotes  Int    @default(0)

  // Figma-related fields for flexibility
  figmaLink   String?
  figmaFields Json?

  // Relationship to User
  // authorId is optional (?) to support fully anonymous submissions without an account
  authorId String?
  author   User?   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  comments Comment[]
  tags     Tag[]

  @@map("reports")
}

// Minimal Comment & Tag models to satisfy relations
model Comment {
  id        String   @id @default(cuid())
  content   String
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())

  @@map("comments")
}

model Tag {
  id      String   @id @default(cuid())
  name    String   @unique
  reports Report[]
}

// Comment model - for discussions on reports

// --- Scraper Models ---

model Politician {
  id             String          @id @default(cuid())
  name           String
  office         String // e.g., "President", "Governor", "MP", "Senator"
  county         String? // The county they are running in (if applicable)
  party          String?
  isCleared      Boolean         @default(false)
  // Relations
  courtCases     CourtCase[]
  socialMentions SocialMention[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("politicians")
}

model CourtCase {
  id          String    @id @default(cuid())
  caseNumber  String    @unique
  courtName   String // e.g., "High Court", "Supreme Court"
  description String // Overview of the allegations/case details
  status      String // e.g., "Pending", "Dismissed", "Ongoing", "Convicted"
  dateFiled   DateTime?
  url         String? // Link to official judiciary/e-filing portal or case PDF
  isVerified  Boolean   @default(true) // Should be checked to ensure no rumors

  politicianId String
  politician   Politician @relation(fields: [politicianId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("court_cases")
}

model SocialMention {
  id       String   @id @default(cuid())
  platform String // e.g., "Twitter"
  content  String
  url      String   @unique
  postedAt DateTime
  isRumour Boolean  @default(false) // Tag to identify unverified claims

  politicianId String
  politician   Politician @relation(fields: [politicianId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("social_mentions")
}
